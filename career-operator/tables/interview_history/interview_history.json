{
  "name": "interview_history",
  "primary_key_column": "id",
  "enable_rls": true,
  "columns": [
    { "name": "application_id", "type": "UUID", "required": true, "foreign_key": { "references": "applications.id" } },
    { "name": "interview_type", "type": "ENUM", "required": true, "default": "unknown", "options": ["unknown", "recruiter_screen", "technical", "behavioral", "system_design", "onsite", "final", "assessment_review"] },
    { "name": "scheduled_at", "type": "DATETIME" },
    { "name": "interviewer", "type": "TEXT", "max_length": 240 },
    { "name": "meeting_url", "type": "TEXT", "max_length": 700 },
    { "name": "notes", "type": "TEXT" },
    { "name": "preparation_file_path", "type": "FILE_PATH", "max_length": 700 },
    { "name": "status", "type": "ENUM", "required": true, "default": "scheduled", "options": ["scheduled", "completed", "rescheduled", "cancelled", "no_show"] }
  ],
  "config": {}
}
